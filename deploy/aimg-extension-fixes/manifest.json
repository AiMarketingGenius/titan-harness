{
  "manifest_version": 3,
  "name": "AI Memory Guard",
  "version": "0.1.7",
  "description": "Persistent memory + fact-checking + hallucination protection across the 7 AI chat platforms. HARDCODED ALLOWLIST \u2014 captures ONLY from the 7 listed AI platforms; all other sites are INVISIBLE to the extension by design (no banking, email, medical, social, chamber sites \u2014 ever).",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://meta.ai/*",
    "https://www.meta.ai/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "platform-detector.js",
        "claude.js",
        "ui/thread-health.js",
        "ui/notification.js",
        "ui/carryover.js",
        "ui/warning-bar.js",
        "ui/einstein-warning.js",
        "ui/einstein-summary.js",
        "ui/cross-llm-inject.js",
        "ui/onboarding.js"
      ],
      "run_at": "document_idle",
      "css": [
        "ui/design-tokens.css",
        "ui/thread-health.css",
        "ui/notification.css",
        "ui/carryover.css",
        "ui/warning-bar.css"
      ]
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "platform-detector.js",
        "chatgpt.js",
        "ui/thread-health.js",
        "ui/notification.js",
        "ui/carryover.js",
        "ui/warning-bar.js",
        "ui/einstein-warning.js",
        "ui/einstein-summary.js",
        "ui/cross-llm-inject.js",
        "ui/onboarding.js"
      ],
      "run_at": "document_idle",
      "css": [
        "ui/design-tokens.css",
        "ui/thread-health.css",
        "ui/notification.css",
        "ui/carryover.css",
        "ui/warning-bar.css"
      ]
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "platform-detector.js",
        "gemini.js",
        "ui/thread-health.js",
        "ui/notification.js",
        "ui/carryover.js",
        "ui/warning-bar.js",
        "ui/einstein-warning.js",
        "ui/einstein-summary.js",
        "ui/cross-llm-inject.js",
        "ui/onboarding.js"
      ],
      "run_at": "document_idle",
      "css": [
        "ui/design-tokens.css",
        "ui/thread-health.css",
        "ui/notification.css",
        "ui/carryover.css",
        "ui/warning-bar.css"
      ]
    },
    {
      "matches": [
        "https://grok.com/*"
      ],
      "js": [
        "platform-detector.js",
        "grok.js",
        "ui/thread-health.js",
        "ui/notification.js",
        "ui/carryover.js",
        "ui/warning-bar.js",
        "ui/einstein-warning.js",
        "ui/einstein-summary.js",
        "ui/cross-llm-inject.js",
        "ui/onboarding.js"
      ],
      "run_at": "document_idle",
      "css": [
        "ui/design-tokens.css",
        "ui/thread-health.css",
        "ui/notification.css",
        "ui/carryover.css",
        "ui/warning-bar.css"
      ]
    },
    {
      "matches": [
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": [
        "platform-detector.js",
        "perplexity.js",
        "ui/thread-health.js",
        "ui/notification.js",
        "ui/carryover.js",
        "ui/warning-bar.js",
        "ui/einstein-warning.js",
        "ui/einstein-summary.js",
        "ui/cross-llm-inject.js",
        "ui/onboarding.js"
      ],
      "run_at": "document_idle",
      "css": [
        "ui/design-tokens.css",
        "ui/thread-health.css",
        "ui/notification.css",
        "ui/carryover.css",
        "ui/warning-bar.css"
      ]
    },
    {
      "matches": [
        "https://copilot.microsoft.com/*"
      ],
      "js": [
        "platform-detector.js",
        "copilot.js",
        "ui/thread-health.js",
        "ui/notification.js",
        "ui/carryover.js",
        "ui/warning-bar.js",
        "ui/einstein-warning.js",
        "ui/einstein-summary.js",
        "ui/cross-llm-inject.js",
        "ui/onboarding.js"
      ],
      "run_at": "document_idle",
      "css": [
        "ui/design-tokens.css",
        "ui/thread-health.css",
        "ui/notification.css",
        "ui/carryover.css",
        "ui/warning-bar.css"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "einstein-demo-claims.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
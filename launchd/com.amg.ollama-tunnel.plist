<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.amg.ollama-tunnel</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/ssh</string>
        <string>-N</string>
        <string>-o</string><string>ServerAliveInterval=30</string>
        <string>-o</string><string>ServerAliveCountMax=3</string>
        <string>-o</string><string>ExitOnForwardFailure=yes</string>
        <string>-o</string><string>StrictHostKeyChecking=no</string>
        <string>-i</string><string>/Users/solonzafiropoulos1/.ssh/id_ed25519_amg</string>
        <string>-L</string><string>21434:127.0.0.1:11434</string>
        <string>amg-staging</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>NetworkState</key>
        <true/>
    </dict>
    <key>ThrottleInterval</key>
    <integer>10</integer>
    <key>StandardOutPath</key>
    <string>/Users/solonzafiropoulos1/.openclaw/logs/ollama-tunnel.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/solonzafiropoulos1/.openclaw/logs/ollama-tunnel.err</string>
</dict>
</plist>

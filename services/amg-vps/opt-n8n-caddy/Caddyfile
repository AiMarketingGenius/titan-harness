    handle @atlas_api {
        reverse_proxy 172.18.0.1:8081
    }

    @atlas_vault_crm path /api/vault/* /api/crm/* /api/revere/* /api/alex/*
    handle @atlas_vault_crm {
        reverse_proxy 172.18.0.1:8081
    }
    @atlas_ws path /ws/voice /ws/voice/* /ws/text /ws/text/*
    handle @atlas_ws {
        reverse_proxy 172.18.0.1:8081
    }
    @atlas_static path /atlas /atlas/* /titan /api/titan/*
    handle @atlas_static {
        reverse_proxy 172.18.0.1:8081
    }
    @kokoro path /kokoro /kokoro/*
    handle @kokoro {
        uri strip_prefix /kokoro
        reverse_proxy 172.18.0.1:8880
    }

    # Chamber partners landing (CT-0418-12 icing)
    @chamberpartners path /chamber-partners /chamber-partners/*
    handle @chamberpartners {
        uri strip_prefix /chamber-partners
        root * /opt/operator-dashboard/chamber-partners
        header Cache-Control "no-cache, must-revalidate"
        file_server
        try_files {path} {path}index.html /index.html
    }

    # Memory Vault Portal (AMG AI Memory Guard consumer surface)
    # Alex public chat demo (revenue-impacting lead-capture landing, 2026-04-20)
    @alexchat path /alex /alex/*
    handle @alexchat {
        uri strip_prefix /alex
        root * /opt/operator-dashboard/alex-chat
        header Cache-Control "no-cache, must-revalidate"
        file_server
        try_files {path} {path}index.html /index.html
    }

    @memoryvault path /memoryvault /memoryvault/*
    handle @memoryvault {
        uri strip_prefix /memoryvault
        root * /opt/operator-dashboard/memoryvault
        header Cache-Control "no-cache, must-revalidate"
        file_server
        try_files {path} {path}index.html /index.html
    }

    # Same-origin Supabase proxy — eliminates browser cross-origin blocks (Safari ITP etc)
    @sbproxy path /supabase/* /auth/v1/* /rest/v1/* /storage/v1/* /realtime/v1/*
    handle @sbproxy {
        uri strip_prefix /supabase
        reverse_proxy https://gaybcxzrzfgvcqpkbeiq.supabase.co {
            header_up Host gaybcxzrzfgvcqpkbeiq.supabase.co
            header_up X-Forwarded-Proto https
            transport http {
                tls
                tls_server_name gaybcxzrzfgvcqpkbeiq.supabase.co
            }
        }
    }

    # /revere — redirect to canonical ops shell (memory subdomain had doc drift, returns 404)
    @revere_path path /revere
    handle @revere_path {
        redir https://ops.aimarketinggenius.io/revere 301
    }

# Existing MCP ingest
    @ingest path /ingest /ingest/*
    handle @ingest {
        reverse_proxy host.docker.internal:9977
    }

    # Default — MCP stateless POST on port 3000
    handle {
        reverse_proxy host.docker.internal:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
                write_timeout 0
            }
        }
    }
    @chamber path /chamber-preview /chamber-preview/*
    handle @chamber {
        uri strip_prefix /chamber-preview
        root * /opt/aimemoryguard-site/chamber-preview
        file_server
    }

}


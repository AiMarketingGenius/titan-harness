n8n.aimarketinggenius.io {
    reverse_proxy n8n:5678
}

memory.aimarketinggenius.io {
    # Atlas voice demo — CT-0415-21 — WebSocket + HTTP API + static orb PWA
    @atlas_api path /api/ask /api/ask/* /api/status /api/agents /api/tts/* /api/backchannel/* /api/dashboard/* /api/alex /api/alex/* /api/chat /api/chat/*
    handle @atlas_api {
        reverse_proxy 172.18.0.1:8081
    }
    @atlas_ws path /ws/voice /ws/voice/* /ws/text /ws/text/*
    handle @atlas_ws {
        reverse_proxy 172.18.0.1:8081
    }
    @atlas_static path /atlas /atlas/* /titan /api/titan/*
    handle @atlas_static {
        reverse_proxy 172.18.0.1:8081
    }
    @kokoro path /kokoro /kokoro/*
    handle @kokoro {
        uri strip_prefix /kokoro
        reverse_proxy 172.18.0.1:8880
    }

    # Existing MCP ingest
    @ingest path /ingest /ingest/*
    handle @ingest {
        reverse_proxy host.docker.internal:9977
    }

    # Default — MCP stateless POST on port 3000
    handle {
        reverse_proxy host.docker.internal:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
                write_timeout 0
            }
        }
    }
}

